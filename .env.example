# Copy to .env. All vars are prefixed CRAWLER_.
# Laptop (dev) defaults are small; the VPS just bumps the concurrency/worker numbers.

# Escalation order. CANONICAL SYSTEM = 3 tiers: L1 -> L2 -> L4 (Web Unlocker catch-all).
# Without L4 creds, run L1,L2. With creds, use: L1,L2,L4
# L2B/L2C/L3 are OPTIONAL dormant modules (off by default). L3 (residential browser) is
# deprioritized — see README "Why L3 is optional". Add any of them here only if you mean to.
CRAWLER_ENABLED_TIERS=L1,L2,L4

# Throttle / concurrency  (VPS: raise these to match vCPU + IP budget)
CRAWLER_GLOBAL_CONCURRENCY=8
CRAWLER_PER_DOMAIN_CONCURRENCY=2
CRAWLER_PER_DOMAIN_MIN_INTERVAL_MS=500
CRAWLER_WORKER_COUNT=4

# Browser (L2/L3)
CRAWLER_HEADLESS=true
# Path to a Chrome/Chromium binary.
#   VPS / Docker / Debian-Ubuntu: /usr/bin/chromium  (default below)
#   macOS local: npx @puppeteer/browsers install chrome@stable  -> use the printed path
#   Or leave empty for nodriver auto-detect.
CRAWLER_CHROME_PATH=/usr/bin/chromium
CRAWLER_BROWSER_CONCURRENCY=2
CRAWLER_NAV_TIMEOUT_S=25
CRAWLER_SETTLE_MS=800
CRAWLER_BLOCK_RESOURCES=true
CRAWLER_IMPERSONATE=chrome

# Classifier thresholds (tune on the benchmark)
CRAWLER_MIN_TEXT_LEN=200
CRAWLER_MIN_RENDER_TEXT_LEN=120

# --- L3: per-IP static residential (ISP) proxies. Comma-separated proxy URLs. ---
# Drop IPs here and add L3 to CRAWLER_ENABLED_TIERS to activate. No code change.
CRAWLER_PROXIES=

# --- L2C: Byparr (Turnstile worker) — URL of a running Byparr/FlareSolverr service ---
CRAWLER_BYPARR_URL=

# --- L4: Bright Data Web Unlocker. Add key+zone and L4 to ENABLED_TIERS to activate. ---
CRAWLER_WEB_UNLOCKER_URL=https://api.brightdata.com/request
CRAWLER_WEB_UNLOCKER_KEY=
CRAWLER_WEB_UNLOCKER_ZONE=

# Queue / store  (dev defaults need zero infra)
CRAWLER_QUEUE_BACKEND=memory
CRAWLER_STORE_BACKEND=sqlite
CRAWLER_DB_URL=crawler.db
CRAWLER_REDIS_URL=redis://localhost:6379
